generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  phone       String   @unique
  email       String?  @unique
  name        String
  avatar_url  String?
  role        String   @default("consumer") // consumer, merchant, admin
  preferences String?  // JSON stringified
  createdAt   DateTime @default(now())

  orders      Order[]
  vouchers    Voucher[]
  bookings    Booking[]
  reviews     Review[]
  merchant    Merchant?
  comments    Comment[]
  likes       Like[]
  follows     Follow[]
}

model Merchant {
  id             String   @id @default(uuid())
  userId         String   @unique
  businessName   String
  category       String
  address        String
  city           String
  status         String   @default("pending") // pending, active, suspended
  bankInfo       String?  // JSON stringified
  commissionRate Float    @default(0.15)
  verifiedAt     DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])
  deals          Deal[]
  livestreams    Livestream[]
  videos         Video[]
  followers      Follow[]
}

model Deal {
  id            String   @id @default(uuid())
  merchantId    String
  title         String
  description   String
  category      String
  originalPrice Float
  dealPrice     Float
  totalQty      Int
  soldQty       Int      @default(0)
  remainingQty  Int
  ratingAvg     Float    @default(0)
  reviewCount   Int      @default(0)
  highlights    String?  // JSON stringified array
  images        String?  // JSON stringified array
  status        String   @default("draft") // draft, active, expired, sold_out
  startsAt      DateTime
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  merchant      Merchant @relation(fields: [merchantId], references: [id])
  vouchers      Voucher[]
  bookings      Booking[]
  reviews       Review[]
  videos        Video[]
}

model Voucher {
  id          String   @id @default(uuid())
  dealId      String
  userId      String
  orderId     String
  qrCode      String   @unique
  status      String   @default("active") // active, redeemed, expired, refunded
  redeemedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id])
  booking     Booking?
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  subtotal      Float
  discount      Float    @default(0)
  total         Float
  paymentMethod String   @default("vnpay") // vnpay, momo, zalopay, bank
  paymentStatus String   @default("pending") // pending, paid, failed, refunded
  paymentRef    String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
  vouchers      Voucher[]
}

model Booking {
  id            String   @id @default(uuid())
  dealId        String
  userId        String
  voucherId     String?  @unique
  bookingDate   DateTime
  slotTime      String
  customerName  String
  customerPhone String
  status        String   @default("pending") // pending, confirmed, completed, cancelled
  notes         String?
  createdAt     DateTime @default(now())

  deal          Deal     @relation(fields: [dealId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  voucher       Voucher? @relation(fields: [voucherId], references: [id])
}

model Review {
  id          String   @id @default(uuid())
  dealId      String
  userId      String
  rating      Int
  content     String
  mediaUrls   String?  // JSON stringified array
  createdAt   DateTime @default(now())

  deal        Deal     @relation(fields: [dealId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Livestream {
  id          String   @id @default(uuid())
  merchantId  String
  title       String
  streamKey   String   @unique
  status      String   @default("scheduled") // scheduled, live, ended
  viewerCount Int      @default(0)
  pinnedDeals String?  // JSON stringified array of dealIds
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime @default(now())

  merchant    Merchant    @relation(fields: [merchantId], references: [id])
  comments    Comment[]
}

model Video {
  id          String   @id @default(uuid())
  merchantId  String
  dealId      String?
  videoUrl    String
  caption     String?
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())

  merchant    Merchant @relation(fields: [merchantId], references: [id])
  deal        Deal?    @relation(fields: [dealId], references: [id])
  comments    Comment[]
  likes       Like[]
}

model Comment {
  id           String   @id @default(uuid())
  userId       String
  videoId      String?
  livestreamId String?
  content      String
  createdAt    DateTime @default(now())

  user         User        @relation(fields: [userId], references: [id])
  video        Video?      @relation(fields: [videoId], references: [id])
  livestream   Livestream? @relation(fields: [livestreamId], references: [id])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  video     Video    @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

model Follow {
  id         String   @id @default(uuid())
  userId     String
  merchantId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  @@unique([userId, merchantId])
}
